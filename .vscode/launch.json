{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            // Use this for normal development when you want the server to restart
            // automatically after code changes.
            "name": "Python Debugger: FastAPI (Reload)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "jinja": true
        },
        {
            // Use this for breakpoint-heavy debugging. It avoids the reload watcher,
            // which makes stepping and breakpoints more predictable.
            "name": "Python Debugger: FastAPI (Debug)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "jinja": true
        }
    ]
}
